{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "src",
		"resolveJsonModule": true,
		"lib": ["ES2022"]
	},
	"include": ["src/cli/**/*", "src/electron/**/*", "src/shared/**/*"],
	"exclude": ["src/renderer/**/*"]
}
